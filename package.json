{
  "name": "@juner/opentelemetry-async-stack-context-manager",
  "version": "0.0.0",
  "description": "A disposable lock controller that wraps navigator.locks",
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "type": "module",
  "main": "./dist/index.mjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.cjs"
      }
    },
    "./tool" : {
      "import": {
        "types": "./dist/tool/index.d.ts",
        "default": "./dist/tool/index.mjs"
      },
      "require": {
        "types": "./dist/tool/index.d.ts",
        "default": "./dist/tool/index.cjs"
      }
    }
  },
  "scripts": {
    "test:watch": "vitest watch --coverage",
    "test": "vitest run --coverage --coverage.reporter=cobertura --coverage.reporter=text",
    "lint": "npx --node-options='--experimental-strip-types' eslint --flag unstable_native_nodejs_ts_config",
    "build": "vite build && tsc --project tsconfig.build.json",
    "clean": "node utils/remove.ts -- -f ./dist -f ./TestResults"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/juner/disposable-lock.git"
  },
  "keywords": [
    "Web",
    "Locks",
    "Web Locks",
    "navigator.locks"
  ],
  "author": "juners",
  "license": "MIT",
  "engines": {
    "node": ">=24.x"
  },
  "bugs": {
    "url": "https://github.com/juner/disposable-lock/issues"
  },
  "homepage": "https://github.com/juner/disposable-lock#readme",
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@eslint/json": "^0.14.0",
    "@eslint/markdown": "^7.5.1",
    "@stylistic/eslint-plugin": "^5.5.0",
    "@types/fs-extra": "^11.0.4",
    "@vitest/coverage-v8": "^4.0.8",
    "eslint": "^9.39.1",
    "fs-extra": "^11.3.2",
    "globals": "^16.5.0",
    "path": "^0.12.7",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.46.4",
    "vite": "^7.2.2",
    "vitest": "^4.0.8"
  },
  "dependencies": {
    "@opentelemetry/api": "^1.9.0"
  }
}
